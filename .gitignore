# --- Glacia Labs Monorepo Gitignore ---

# Python (Backend)
backend/venv/
backend/.venv/
backend/__pycache__/
backend/*.py[cod]
backend/*.so
backend/.pytest_cache/
backend/.env
backend/audio_cache/
backend/*.mp3

# Node.js (Frontend)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/.vercel

# Databases & OS
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/
*.swp

# Security (Crucial for Glacia Labs)
.env
secret.txt
keys.json